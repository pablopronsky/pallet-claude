// Prisma schema — Nuevo Parket (Control de Consignación)
// Base de datos: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------------------------
// ENUMS
// -------------------------------------------------------------------

enum Rol {
  ADMIN
  VENDEDOR
}

enum Sucursal {
  QUILMES
  LA_PLATA
  GONNET
}

enum Motivo {
  MUESTRA
  ROTURA
  DONACION
  VENCIMIENTO
  OTRO
}

enum Moneda {
  ARS
  USD
}

enum OrigenIngreso {
  PROVEEDOR
  TRANSFERENCIA
}

// -------------------------------------------------------------------
// MODELOS
// -------------------------------------------------------------------

model User {
  id        String    @id @default(cuid())
  nombre    String
  email     String    @unique
  password  String
  rol       Rol
  sucursal  Sucursal?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ingresos       Ingreso[]       @relation("IngresoAdmin")
  ventas         Venta[]         @relation("VentaUser")
  bajas          Baja[]          @relation("BajaAdmin")
  transferencias Transferencia[] @relation("TransferenciaAdmin")
  liquidaciones  Liquidacion[]   @relation("LiquidacionAdmin")

  @@unique([rol, sucursal])
  @@index([email])
}

model Producto {
  id          String   @id @default(cuid())
  nombre      String   @unique
  activo      Boolean  @default(true)
  stockMinimo Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingresos       Ingreso[]
  ventas         Venta[]
  bajas          Baja[]
  transferencias Transferencia[]

  @@index([activo])
}

model Ingreso {
  id                 String        @id @default(cuid())
  productoId         String
  sucursal           Sucursal
  cantidadCajas      Int
  precioCostoPorCaja Decimal       @db.Decimal(14, 2)
  moneda             Moneda        @default(ARS)
  tipoCambio         Decimal?      @db.Decimal(12, 4)
  origen             OrigenIngreso @default(PROVEEDOR)
  fecha              DateTime      @default(now())
  adminId            String
  notas              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  admin    User     @relation("IngresoAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  ventas   Venta[]

  transferenciasOrigen Transferencia[] @relation("TransferOrigen")
  transferenciaDestino Transferencia?  @relation("TransferDestino")

  @@index([productoId])
  @@index([sucursal])
  @@index([fecha])
  @@index([origen])
}

model Venta {
  id                 String   @id @default(cuid())
  productoId         String
  ingresoId          String
  sucursal           Sucursal
  cantidadCajas      Int
  precioVentaPorCaja Decimal  @db.Decimal(14, 2)
  moneda             Moneda   @default(ARS)
  tipoCambio         Decimal? @db.Decimal(12, 4)
  fecha              DateTime @default(now())
  userId             String
  notas              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  ingreso  Ingreso  @relation(fields: [ingresoId], references: [id], onDelete: Restrict)
  user     User     @relation("VentaUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([productoId])
  @@index([ingresoId])
  @@index([sucursal])
  @@index([fecha])
  @@index([userId])
}

model Baja {
  id            String   @id @default(cuid())
  productoId    String
  sucursal      Sucursal
  cantidadCajas Int
  motivo        Motivo
  fecha         DateTime @default(now())
  adminId       String
  notas         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  admin    User     @relation("BajaAdmin", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([productoId])
  @@index([sucursal])
  @@index([fecha])
}

// Transferencia de cajas entre sucursales.
// Internamente: descarga cajas del ingreso origen y crea un Ingreso "clon" en destino
// con origen=TRANSFERENCIA y mismo costo/moneda/TC, para preservar la trazabilidad FIFO.
model Transferencia {
  id               String   @id @default(cuid())
  productoId       String
  sucursalOrigen   Sucursal
  sucursalDestino  Sucursal
  cantidadCajas    Int
  fecha            DateTime @default(now())
  adminId          String
  notas            String?
  ingresoOrigenId  String
  ingresoDestinoId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  producto       Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  admin          User     @relation("TransferenciaAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  ingresoOrigen  Ingreso  @relation("TransferOrigen", fields: [ingresoOrigenId], references: [id], onDelete: Restrict)
  ingresoDestino Ingreso  @relation("TransferDestino", fields: [ingresoDestinoId], references: [id], onDelete: Restrict)

  @@index([productoId])
  @@index([sucursalOrigen])
  @@index([sucursalDestino])
  @@index([fecha])
}

// Pago / liquidación al proveedor (All Covering SRL).
// Permite calcular deuda neta = sum(costo de ventas) - sum(liquidaciones).
model Liquidacion {
  id          String   @id @default(cuid())
  fecha       DateTime @default(now())
  monto       Decimal  @db.Decimal(14, 2)
  moneda      Moneda   @default(ARS)
  tipoCambio  Decimal? @db.Decimal(12, 4)
  comprobante String?
  notas       String?
  adminId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin User @relation("LiquidacionAdmin", fields: [adminId], references: [id], onDelete: Restrict)

  @@index([fecha])
}
